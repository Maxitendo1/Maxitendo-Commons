<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="BottomActionMenuItem">
        <attr name="android:id" />
        <attr name="android:title" />
        <attr name="android:icon" />
        <attr name="android:visible" />
        <attr name="showAsAction" />
    </declare-styleable>

    <!-- IndicatorFastScroll attributes -->
    <attr name="indicatorFastScrollerStyle" format="reference" />
    <attr name="indicatorFastScrollerThumbStyle" format="reference" />

    <attr name="fastScrollerIconColor" format="color" />
    <attr name="fastScrollerTextPadding" format="dimension" />
    <attr name="fastScrollerThumbColor" format="color" />

    <declare-styleable name="FastScrollerView">
        <attr name="fastScrollerIconColor" />
        <attr name="android:textAppearance" />
        <attr name="android:textColor" />
        <attr name="fastScrollerTextPadding" />
    </declare-styleable>

    <declare-styleable name="FastScrollerThumbView">
        <attr name="fastScrollerThumbColor" />
        <attr name="fastScrollerIconColor" />
        <attr name="android:textAppearance" />
        <attr name="android:textColor" />
    </declare-styleable>

    <!-- SwipeActionView attributes -->
    <declare-styleable name="SwipeActionView">
        <attr name="sav_swipeLeftRippleColor" format="color|reference"/>
        <attr name="sav_swipeRightRippleColor" format="color|reference"/>
        <attr name="sav_rippleTakesPadding" format="boolean"/>

        <attr name="sav_tools_previewBackground" format="integer">
            <!-- Preview background for swipe left gesture -->
            <enum name="swipeLeft" value="1"/>
            <!-- Preview background for swipe right gesture -->
            <enum name="swipeRight" value="2"/>
        </attr>

        <attr name="sav_tools_previewRipple" format="integer">
            <!-- Preview ripple for swipe left gesture -->
            <enum name="swipeLeft" value="1"/>
            <!-- Preview ripple for swipe right gesture -->
            <enum name="swipeRight" value="2"/>
        </attr>
    </declare-styleable>
</resources>
